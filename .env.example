# Fixed upstream reference for reproducible builds.
COMFYUI_REF=v0.9.2

# PyTorch channel:
# - stable: torch/torchvision/torchaudio from cu130
# - nightly: torch/torchvision/torchaudio from nightly cu132
TORCH_CHANNEL=stable
# ComfyUI-Manager optional matrix sharing dependency
INSTALL_MATRIX_NIO=true

# Image naming
IMAGE_NAME=comfyui-local
IMAGE_TAG=latest

# Container runtime user (avoid root-owned files on bind mounts)
LOCAL_UID=1000
LOCAL_GID=1000
# Logical username injected into container env (used by Python/getpass and torch cache code)
COMFY_RUNTIME_USER=comfyui

# ComfyUI web binding
COMFYUI_HOST=0.0.0.0
COMFYUI_PORT=8188
# Defaults:
# - --enable-manager activates ComfyUI-Manager UI
# - --preview-method auto enables better preview selection automatically
COMFYUI_EXTRA_ARGS="--enable-manager --preview-method auto"

# Optional: set true to force CUDA availability check at startup.
COMFY_PRECHECK_CUDA=false

# ComfyUI-Manager policy defaults (required for install/download actions in remote setups)
COMFY_MANAGER_ENFORCE_CONFIG=true
COMFY_MANAGER_SECURITY_LEVEL=normal
COMFY_MANAGER_NETWORK_MODE=personal_cloud

# Host bind mount directories
COMFY_MODELS_BIND=./data/models
COMFY_CUSTOM_NODES_BIND=./data/custom_nodes
COMFY_INPUT_BIND=./data/input
COMFY_OUTPUT_BIND=./data/output
COMFY_USER_BIND=./data/user
COMFY_TEMP_BIND=./data/temp
# Workflow exports and editable variants (ignored from git on purpose)
COMFY_WORKFLOWS_BIND=./data/workflows

# Optional model download tokens for scripts/model-download.sh
HF_TOKEN=
CIVITAI_TOKEN=

# uv installer behavior used by ComfyUI-Manager install scripts
UV_LINK_MODE=copy

# Optional GPU-specific env vars used by docker-compose.gpu.yml
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
