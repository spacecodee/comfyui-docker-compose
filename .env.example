# Local ComfyUI setup (no Docker)

# ComfyUI source checkout
COMFYUI_REPO_URL=https://github.com/Comfy-Org/ComfyUI.git
COMFYUI_REF=master
COMFYUI_DIR=./comfyui

# Local Python environment
# Recommended: python3.13
# If some custom node dependencies fail on 3.13, try python3.12
# Python 3.14 works but some custom nodes may have issues
# Set false in environments that disallow creating virtualenvs
COMFY_USE_VENV=true
COMFY_PYTHON_BIN=python3
COMFY_VENV_DIR=./.venv

# Shared project directories linked into ComfyUI
COMFY_WORKFLOWS_DIR=./data/workflows
COMFY_INPUT_DIR=./data/input
COMFY_OUTPUT_DIR=./data/output
# Optional override for model destination root
# Default when empty: <COMFYUI_DIR>/models
COMFY_MODELS_DIR=

# ComfyUI web server
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
COMFYUI_PREVIEW_METHOD=auto
COMFYUI_EXTRA_ARGS=--enable-manager

# Preview models setup
# - true: auto download TAESD preview decoders during setup when method is auto/taesd
# - false: skip auto download and use manual script when needed
COMFY_PREVIEW_AUTO_SETUP=true
# Optional override for decoder download source
COMFY_PREVIEW_MODELS_BASE_URL=https://raw.githubusercontent.com/madebyollin/taesd/main

# Custom node dependency auto-install
COMFY_AUTO_INSTALL_CUSTOM_NODE_DEPS=true
COMFY_CUSTOM_NODE_DEPS_STRICT=false
COMFY_CUSTOM_NODE_DEPS_FORCE=false

# Startup dependency maintenance
# - Sync ComfyUI requirements.txt automatically when it changes
COMFY_AUTO_SYNC_REQUIREMENTS=true
# - If --enable-manager is active, install manager_requirements.txt when needed
COMFY_AUTO_INSTALL_MANAGER_REQUIREMENTS=true
# - If torchaudio import is broken, try auto-repair to match installed torch
COMFY_AUTO_FIX_TORCHAUDIO=true

# Optional tokens for model downloads
HF_TOKEN=
CIVITAI_TOKEN=
